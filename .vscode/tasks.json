{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build reqlan",
            "command": "pnpm run build",
            "type": "shell",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Langium: Generate grammar and build the reqlan language",
            "icon": {
                "color": "terminal.ansiGreen",
                "id": "server-process"
            }
        },
        {
            "label": "Watch reqlan",
            "command": "pnpm run watch",
            "type": "shell",
            "isBackground": true,
            "problemMatcher": "$tsc-watch",
            "detail": "Langium, TypeScript, and extension bundler watch for grammar and language server changes",
            "icon": {
                "color": "terminal.ansiYellow",
                "id": "eye"
            }
        },
        {
            "label": "Run Extension (new window)",
            "command": "cursor --extensionDevelopmentPath=\"${workspaceFolder}/packages/extension\" \"${workspaceFolder}/reqlan-debug.code-workspace\"",
            "type": "shell",
            "detail": "Launch the reqlan extension in an Extension Development Host window (equivalent to the 'Run Extension' launch config). Uses the 'cursor' CLI so it works inside a Cursor Remote-WSL session; change to 'code' if running in a native VS Code + Remote-WSL setup.",
            "problemMatcher": [],
            "icon": {
                "color": "terminal.ansiBlue",
                "id": "vscode"
            }
        }
    ]
}
