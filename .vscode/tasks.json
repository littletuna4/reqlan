{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build reqlan",
            "command": "pnpm run build",
            "type": "shell",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Langium: Generate grammar and build the reqlan language",
            "icon": {
                "color": "terminal.ansiGreen",
                "id": "server-process"
            }
        },
        {
            "label": "Watch reqlan",
            "command": "pnpm run watch",
            "type": "shell",
            "isBackground": true,
            "problemMatcher": "$tsc-watch",
            "detail": "Langium, TypeScript, and extension bundler watch for grammar and language server changes",
            "icon": {
                "color": "terminal.ansiYellow",
                "id": "eye"
            }
        },
        {
            "label": "Run Extension (new window)",
            "command": "cursor \"${workspaceFolder}/reqlan-debug.code-workspace\"",
            "type": "shell",
            "detail": "Open the debug workspace in Cursor. For extension development with an isolated profile, use the 'Run Extension' launch config (F5) instead — the Cursor WSL CLI ignores --user-data-dir, --profile-temp, and --extensionDevelopmentPath.",
            "problemMatcher": [],
            "icon": {
                "color": "terminal.ansiBlue",
                "id": "vscode"
            }
        }
    ]
}
