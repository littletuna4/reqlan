{
    "name": "vscode-reqlan-extension",
    "description": "The extension specific package",
    "version": "0.0.1",
    "displayName": "reqlan",
    "type": "module",
    "publisher": "btdigital",
    "license": "AGPL-3.0-only",
    "repository": {
        "type": "git",
        "url": "https://github.com/littletuna4/reqlan.git"
    },
    "engines": {
        "vscode": "^1.91.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [{
            "id": "reqlan",
            "aliases": ["reqlan", "rq"],
            "extensions": [".rq"],
            "configuration": "./language-configuration.json"
        }],
        "grammars": [{
            "language": "reqlan",
            "scopeName": "source.reqlan",
            "path": "syntaxes/reqlan.tmLanguage.json"
        }, {
            "scopeName": "comment.rq.injection",
            "injectTo": [
                "source.python",
                "source.js",
                "source.ts",
                "source.tsx",
                "source.java",
                "source.go",
                "source.rust",
                "source.c",
                "source.cpp"
            ],
            "path": "./syntaxes/reqlan-comment.injection.json"
        }],
        "semanticTokenScopes": [
            {
                "language": "reqlan",
                "scopes": {
                    "decorator": ["entity.name.tag.attribute.reqlan"],
                    "operator": ["punctuation.definition.attribute.reqlan"]
                }
            }
        ],
        "configurationDefaults": {
            "[reqlan]": {
                "editor.semanticHighlighting.enabled": true
            }
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "reqlan",
                    "title": "Reqlan",
                    "icon": "media/reqlan-activity.svg"
                }
            ]
        },
        "views": {
            "reqlan": [
                {
                    "id": "reqlan.activityBar",
                    "name": "Context"
                }
            ]
        },
        "commands": [
            {
                "command": "reqlan.listAllIdeas",
                "title": "Reqlan: List All Ideas",
                "category": "Reqlan"
            },
            {
                "command": "reqlan.fileRelatedRequirements",
                "title": "Reqlan: File Related Requirements",
                "category": "Reqlan"
            },
            {
                "command": "reqlan.deprecationImpact",
                "title": "Reqlan: Deprecation Impact Analysis",
                "category": "Reqlan"
            },
            {
                "command": "reqlan.completionStatus",
                "title": "Reqlan: Completion Status",
                "category": "Reqlan"
            },
            {
                "command": "reqlan.getLocalGraph",
                "title": "Reqlan: Get Local Graph",
                "category": "Reqlan"
            },
            {
                "command": "reqlan.semanticSearch",
                "title": "Reqlan: Semantic Search",
                "category": "Reqlan"
            },
            {
                "command": "reqlan.refreshIndex",
                "title": "Reqlan: Refresh Idea Index",
                "category": "Reqlan"
            },
            {
                "command": "reqlan.refreshActivityBar",
                "title": "Refresh",
                "icon": "$(refresh)"
            },
            {
                "command": "reqlan.openIdeaFromActivityBar",
                "title": "Open Idea"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "reqlan.refreshActivityBar",
                    "when": "view == reqlan.activityBar",
                    "group": "navigation"
                }
            ]
        }
    },
    "activationEvents": [
        "onLanguage:reqlan",
        "onStartupFinished"
    ],
    "main": "./out/extension/main.cjs",
    "scripts": {
        "clean": "shx rm -fr *.tsbuildinfo out syntaxes",
        "vscode:prepublish": "pnpm run build",
        "build:prepare": "shx mkdir -p ./syntaxes/ && shx cp -f ../language/syntaxes/reqlan.tmLanguage.json ./syntaxes/reqlan.tmLanguage.json",
        "build": "pnpm run build:prepare && tsc -b tsconfig.json && node esbuild.mjs",
        "build:clean": "pnpm run clean && pnpm run build",
        "watch": "concurrently -n tsc,esbuild,syntax -c blue,yellow,cyan \"tsc -b tsconfig.json --watch\" \"node esbuild.mjs --watch\" \"node watch-syntax.mjs\""
    },
    "dependencies": {
        "better-sqlite3": "~11.10.0",
        "langium": "~4.3.0",
        "reqlan-language": "workspace:*",
        "vscode-languageclient": "~10.0.0",
        "vscode-languageserver": "~10.0.0",
        "vscode-languageserver-textdocument": "~1.0.12",
        "zustand": "~5.0.8"
    },
    "devDependencies": {
        "@types/better-sqlite3": "~7.6.13",
        "@types/vscode": "~1.91.0",
        "concurrently": "~10.0.3",
        "esbuild": "~0.28.1"
    },
    "vsce": {
      "dependencies": true
    }
}
