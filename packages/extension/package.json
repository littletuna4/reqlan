{
    "name": "reqlan",
    "description": "Language support for the reqlan language",
    "version": "0.0.1",
    "displayName": "reqlan support",
    "type": "module",
    "publisher": "reqlan",
    "license": "AGPL-3.0-only",
    "repository": {
        "type": "git",
        "url": "https://github.com/littletuna4/reqlan.git"
    },
    "engines": {
        "vscode": "^1.91.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "reqlan",
                "aliases": [
                    "reqlan",
                    "rq"
                ],
                "extensions": [
                    ".rq"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "reqlan",
                "scopeName": "source.reqlan",
                "path": "syntaxes/reqlan.tmLanguage.json"
            }
        ],
        "semanticTokenScopes": [
            {
                "language": "reqlan",
                "scopes": {
                    "decorator": [
                        "entity.name.tag.attribute.reqlan"
                    ],
                    "operator": [
                        "punctuation.definition.attribute.reqlan"
                    ]
                }
            }
        ],
        "configurationDefaults": {
            "[reqlan]": {
                "editor.semanticHighlighting.enabled": true
            }
        },
        "configuration": {
            "title": "Reqlan",
            "properties": {
                "reqlan.referencesInlayHints.enabled": {
                    "type": "boolean",
                    "default": false,
                    "description": "Show inbound references as a @referenced-by inlay attribute on idea declarations in .rq editors."
                }
            }
        },
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "reqlan",
                    "title": "Reqlan",
                    "icon": "media/logo.svg"
                }
            ]
        },
        "views": {
            "reqlan": [
                {
                    "id": "reqlan.activityBar",
                    "name": "Context"
                }
            ]
        },
        "chatAgents": [
            {
                "path": "./agents/reqlan.agent.md"
            }
        ],
        "chatSkills": [
            {
                "path": "./skills/rq-requirements/SKILL.md"
            },
            {
                "path": "./skills/rq-search/SKILL.md"
            }
        ],
        "chatPromptFiles": [
            {
                "path": "./prompts/rq-build-requirement.prompt.md"
            },
            {
                "path": "./prompts/rq-add-to-context.prompt.md"
            },
            {
                "path": "./prompts/rq-write-plan.prompt.md"
            },
            {
                "path": "./prompts/rq-search-requirements.prompt.md"
            },
            {
                "path": "./prompts/rq-file-context.prompt.md"
            }
        ],
        "chatParticipants": [
            {
                "id": "reqlan.reqlan",
                "name": "reqlan",
                "fullName": "Reqlan",
                "description": "Ask about requirements, search the graph, or attach #requirement / #file context.",
                "isSticky": true,
                "commands": [
                    {
                        "name": "rq-search",
                        "description": "Search requirements by keyword across names, summaries, and tags"
                    },
                    {
                        "name": "rq-context",
                        "description": "Summarise requirements related to the active file"
                    },
                    {
                        "name": "rq-graph",
                        "description": "Show the local requirement graph around the current file"
                    },
                    {
                        "name": "rq-related",
                        "description": "List requirements that reference or are referenced by the active file"
                    }
                ]
            }
        ],
        "languageModelTools": [
            {
                "name": "reqlan_requirement_reference",
                "toolReferenceName": "requirement",
                "displayName": "Requirement",
                "modelDescription": "Resolve a reqlan requirement by name or keyword and return a compact summary for chat context.",
                "userDescription": "Attach a requirement from the workspace graph.",
                "canBeReferencedInPrompt": true,
                "icon": "$(symbol-class)",
                "inputSchema": {
                    "type": "object",
                    "properties": {
                        "name": {
                            "type": "string",
                            "description": "Requirement name or search text. Leave empty to list nearby matches."
                        }
                    }
                }
            },
            {
                "name": "reqlan_file_reference",
                "toolReferenceName": "file",
                "displayName": "Reqlan File",
                "modelDescription": "Resolve a .rq file and return the requirements indexed in that file.",
                "userDescription": "Attach requirements from a reqlan file.",
                "canBeReferencedInPrompt": true,
                "icon": "$(file)",
                "inputSchema": {
                    "type": "object",
                    "properties": {
                        "path": {
                            "type": "string",
                            "description": "Relative path fragment for a .rq file in the workspace."
                        }
                    }
                }
            }
        ],
        "commands": [
            {
                "command": "reqlan.listAllIdeas",
                "title": "List All Ideas",
                "category": "Reqlan"
            },
            {
                "command": "reqlan.fileRelatedRequirements",
                "title": "File Related Requirements",
                "category": "Reqlan"
            },
            {
                "command": "reqlan.deprecationImpact",
                "title": "Deprecation Impact Analysis",
                "category": "Reqlan"
            },
            {
                "command": "reqlan.completionStatus",
                "title": "Completion Status",
                "category": "Reqlan"
            },
            {
                "command": "reqlan.getLocalGraph",
                "title": "Get Local Graph",
                "category": "Reqlan"
            },
            {
                "command": "reqlan.semanticSearch",
                "title": "Semantic Search",
                "category": "Reqlan"
            },
            {
                "command": "reqlan.refreshIndex",
                "title": "Refresh Idea Index",
                "category": "Reqlan"
            },
            {
                "command": "reqlan.refreshActivityBar",
                "title": "Refresh",
                "icon": "$(refresh)"
            },
            {
                "command": "reqlan.openIdeaFromActivityBar",
                "title": "Open Idea"
            },
            {
                "command": "reqlan.toggleReferenceInlayHints",
                "title": "Toggle Reference Inlay Hints",
                "category": "Reqlan"
            },
            {
                "command": "reqlan.openFolderReference",
                "title": "Open Folder Reference"
            },
            {
                "command": "reqlan.openIdeasSummary",
                "title": "Open Ideas Summary",
                "category": "Reqlan",
                "icon": "$(table)"
            },
            {
                "command": "reqlan.installCursorSkills",
                "title": "Install Cursor Skills",
                "category": "Reqlan"
            },
            {
                "command": "reqlan.addAgentCommands",
                "title": "Install Cursor Skills",
                "category": "Reqlan"
            },
            {
                "command": "reqlan.buildRequirement",
                "title": "Build New Requirement",
                "category": "Reqlan"
            },
            {
                "command": "reqlan.addToContext",
                "title": "Add to Context",
                "category": "Reqlan"
            },
            {
                "command": "reqlan.writePlan",
                "title": "Write Plan",
                "category": "Reqlan"
            },
            {
                "command": "reqlan.runPrompt",
                "title": "Run Chat Prompt",
                "category": "Reqlan"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "reqlan.openIdeasSummary",
                    "when": "view == reqlan.activityBar",
                    "group": "navigation@1"
                },
                {
                    "command": "reqlan.refreshActivityBar",
                    "when": "view == reqlan.activityBar",
                    "group": "navigation@2"
                }
            ]
        }
    },
    "activationEvents": [
        "onCommand:reqlan.installCursorSkills",
        "onCommand:reqlan.addAgentCommands",
        "onCommand:reqlan.buildRequirement",
        "onCommand:reqlan.addToContext",
        "onCommand:reqlan.writePlan",
        "onCommand:reqlan.runPrompt",
        "onCommand:reqlan.openIdeasSummary",
        "onCommand:reqlan.toggleReferenceInlayHints",
        "onChatParticipant:reqlan.reqlan",
        "onLanguage:reqlan",
        "onLanguage:python",
        "onLanguage:javascript",
        "onLanguage:typescript",
        "onLanguage:typescriptreact"
    ],
    "main": "./out/extension/main.cjs",
    "scripts": {
        "clean": "shx rm -fr *.tsbuildinfo out syntaxes media/webviews",
        "vscode:prepublish": "pnpm run build",
        "build:prepare": "shx mkdir -p ./syntaxes/ && shx cp -f ../language/syntaxes/reqlan.tmLanguage.json ./syntaxes/reqlan.tmLanguage.json && shx cp -f ./grammars/reqlan-comment.injection.json ./syntaxes/reqlan-comment.injection.json && node ../../scripts/sync-cursor-ai.mjs",
        "build:webviews": "vite build --config webviews/ideas-summary/vite.config.ts",
        "build": "pnpm run build:prepare && pnpm run build:webviews && tsc -b tsconfig.json && node esbuild.mjs",
        "build:clean": "pnpm run clean && pnpm run build",
        "watch": "concurrently -n webviews,tsc,esbuild,syntax -c magenta,blue,yellow,cyan \"vite build --config webviews/ideas-summary/vite.config.ts --watch\" \"tsc -b tsconfig.json --watch\" \"node esbuild.mjs --watch\" \"node watch-syntax.mjs\""
    },
    "dependencies": {
        "d3-force": "^3.0.0",
        "langium": "~4.3.0",
        "reqlan-analytical": "workspace:*",
        "reqlan-language": "workspace:*",
        "sqlite3": "~5.1.7",
        "vscode-languageclient": "~10.0.0",
        "vscode-languageserver": "~10.0.0",
        "vscode-languageserver-textdocument": "~1.0.12",
        "zustand": "~5.0.8"
    },
    "devDependencies": {
        "@sveltejs/vite-plugin-svelte": "~3.1.2",
        "@tsconfig/svelte": "~5.0.4",
        "@types/d3-force": "^3.0.10",
        "@types/vscode": "~1.91.0",
        "concurrently": "~10.0.3",
        "esbuild": "~0.28.1",
        "svelte": "~4.2.19",
        "vite": "~5.4.11"
    },
    "vsce": {
        "dependencies": true
    }
}
