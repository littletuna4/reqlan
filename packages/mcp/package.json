{
    "name": "reqlan-mcp",
    "description": "MCP server exposing reqlan requirement graph tools",
    "version": "0.0.1",
    "type": "module",
    "license": "AGPL-3.0-only",
    "engines": {
        "node": ">=20.10.0"
    },
    "bin": {
        "reqlan-mcp": "./bin/mcp.js"
    },
