import "../extension/configuration.rq" as configuration

import_keywords {
    The keywords import, from, and as are reserved for import statements.
    Import keywords may also appear as ordinary words in idea body text when not at statement start.
}

import_from {
    From-import syntax uses from, a quoted path, import, and an idea name.
    From-import may include an alias using as.

    @example {
        from "example.rq" import idea
    }

    @tests (
        ["../../packages/language/test/parsing.test.ts:parses from-import example line inside an attribute block value"]
    )
}

import_namespace {
    Namespace import syntax uses import and a quoted path.
    Namespace import may include an alias using as.
    A bracket reference to the alias alone — for example [context_model] — opens the imported file and links only the alias name, like an ideaset namespace.
    Qualified references through the alias — for example [context_model.builder] — resolve ideas from the imported module.

    @tests (
        ["../../packages/language/test/linking.test.ts:resolve namespace import references to files"]
        ["../../packages/language/test/linking.test.ts:namespace import bracket reference links only the alias name"]
    )
}

import_qualified {
    Qualified import syntax uses import, a quoted path, a dot, an ideaset name, a dot, and an idea name.
    Qualified import may include an alias using as.
}

import_paths {
    Import path strings may use relative paths such as ./exampleimport.rq.
    Import path strings may use paths containing folders.
    Import path strings may use remote urls such as https://company.com/reqs/style.rq.
}

configuration_import_root_alias {
    An import path may start with an alias string, then `/`, then a relative path.
    Default alias string: `@`.
    Default import-root directory: the workspace folder that contains the `.rq` file.
    The path after `/` is joined to that alias's import-root directory.
    Alias strings and import-root directories are configured as [configuration.configuration_import_roots] in the applying `.rqconfig.json` from [configuration.configuration_location].
    When several configured aliases could match a path, the longest alias wins.
    Implemented by ["../../packages/language/src/reqlan-path-resolve.ts"], ["../../packages/language/src/file-path-rewrite.ts"], and ["../../packages/language/src/reqlan-completion-provider.ts"].
    @tests (
        ["../../packages/language/test/path-resolve.test.ts:resolves import-root alias against the workspace folder"]
        ["../../packages/language/test/path-resolve.test.ts:leaves non-aliased relative paths document-relative"]
        ["../../packages/language/test/path-resolve.test.ts:matchImportRootAlias requires alias then slash"]
        ["../../packages/language/test/path-resolve.test.ts:loads importRoots list from nearest rqconfig"]
        ["../../packages/language/test/path-resolve.test.ts:resolves using config importRoots mapping"]
        ["../../packages/language/test/path-resolve.test.ts:rewrite leaves aliased paths unchanged"]
        ["../../packages/language/test/completion.test.ts:completes import-root alias paths"]
        ["../../packages/language/test/rqconfig.test.ts:multiple importRoots map aliases to different roots"]
        ["../../packages/language/test/rqconfig.test.ts:longest alias wins when mappings overlap"]
    )
}

anonymous_imports_allowed {
    imports can be inlined with this syntax: `["./ontology.rq".attribute]`. i.e. file references import the file as an ideaset.
}
