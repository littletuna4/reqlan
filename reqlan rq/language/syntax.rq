idea4 {
    ```mermaid
    hello 
    ```
    @attribute {
        hellos
    }
    @boolean_attribute true
    @prose_attribute hello
    @ideaset_attribute (
        [idea1],
        [idea2],
        [idea3],
    )
    @attribute_with_value 123
    @reference_attribute [idea4]
}

