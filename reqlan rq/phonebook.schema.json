{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "reqlan phonebook",
  "type": "object",
  "additionalProperties": false,
  "required": ["icons", "links"],
  "properties": {
    "icons": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["package", "iconifyPrefix", "catalog", "search"],
        "properties": {
          "package": {
            "type": "string",
            "minLength": 1
          },
          "iconifyPrefix": {
            "type": "string",
            "minLength": 1
          },
          "catalog": {
            "type": "string",
            "minLength": 1
          },
          "search": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "links": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "href", "icon"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1
          },
          "href": {
            "type": "string",
            "minLength": 1
          },
          "icon": {
            "type": "object",
            "additionalProperties": false,
            "required": ["set", "name"],
            "properties": {
              "set": {
                "type": "string",
                "minLength": 1
              },
              "name": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
